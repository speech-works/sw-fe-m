{
  "name": "sw-fe-m",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start:dev": "npx expo start --dev-client --port 3003",
    "start": "npx expo start",
    "start:tunnel": "npx expo start --tunnel",
    "web": "npx expo start --web",
    "prebuild": "npx expo prebuild --clean",
    "prebuild:android": "npx expo prebuild --platform android",
    "prebuild:ios": "npx expo prebuild --platform ios",
    "install:android": "npx expo run:android",
    "install:ios": "npx expo run:ios",
    "clean:js": "rm -rf node_modules yarn.lock package-lock.json && watchman watch-del-all",
    "clean:native": "rm -rf ios/Podfile.lock ios/Pods android/build android/.gradle && npx expo prebuild --clean",
    "reinstall:deps": "npm install && cd ios && pod install --repo-update && cd ..",
    "rebuild:ios:fresh": "npm run clean:js && npm run clean:native && npm run reinstall:deps && npm run install:ios",
    "reinstall:pods": "cd ios && rm -rf Pods Podfile.lock && pod install --repo-update && cd ..",
    "rebuild:android:fresh": "npm run reinstall:deps && npm run clean:native && npm run install:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:preview": "eas build -p android --profile preview-apk",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:android:local:apk": "watchman watch-del-all >/dev/null 2>&1 || true; (cd android 2>/dev/null && ./gradlew --stop >/dev/null 2>&1) || true; rm -rf .expo node_modules/.cache \"${TMPDIR:-/tmp}\"metro-* \"${TMPDIR:-/tmp}\"haste-map-* >/dev/null 2>&1 || true; mkdir -p dist; ANDROID_HOME=\"${ANDROID_HOME:-$HOME/Library/Android/sdk}\" ANDROID_SDK_ROOT=\"${ANDROID_SDK_ROOT:-$HOME/Library/Android/sdk}\" eas build -p android --local --profile preview-apk --output ./dist/sw-fe-m.apk",
    "build:android:local": "watchman watch-del-all >/dev/null 2>&1 || true; (cd android 2>/dev/null && ./gradlew --stop >/dev/null 2>&1) || true; rm -rf .expo node_modules/.cache \"${TMPDIR:-/tmp}\"metro-* \"${TMPDIR:-/tmp}\"haste-map-* >/dev/null 2>&1 || true; mkdir -p dist; ANDROID_HOME=\"${ANDROID_HOME:-$HOME/Library/Android/sdk}\" ANDROID_SDK_ROOT=\"${ANDROID_SDK_ROOT:-$HOME/Library/Android/sdk}\" eas build -p android --local --profile production --output ./dist/sw-fe-m.aab",
    "build:ios:local": "eas build -p ios --local --profile preview",
    "build:android:production": "eas build -p android --profile production",
    "build:ios:production": "eas build -p ios --profile production",
    "logs:android": "adb logcat '*:S' 'ReactNative:V' 'ReactNativeJS:V'",
    "postinstall": "patch-package",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:store-compliance": "bash scripts/check-store-compliance.sh"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@dr.pogodin/react-native-audio": "^1.16.0",
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo/config-plugins": "~10.1.2",
    "@expo/vector-icons": "^14.0.0",
    "@posthog/core": "1.27.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.3.0",
    "@react-native-community/slider": "4.5.6",
    "@react-navigation/bottom-tabs": "^7.3.15",
    "@react-navigation/native": "^7.1.11",
    "@react-navigation/native-stack": "^7.3.16",
    "@sentry/react-native": "^8.14.0",
    "axios": "^1.10.0",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "expo": "^53.0.0",
    "expo-auth-session": "^6.1.5",
    "expo-av": "~15.1.4",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.6",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linear-gradient": "~14.1.4",
    "expo-localization": "^16.1.5",
    "expo-modules-core": "^2.3.13",
    "expo-notifications": "~0.31.3",
    "expo-secure-store": "^14.2.3",
    "expo-sensors": "~14.1.4",
    "expo-speech": "~13.1.7",
    "expo-speech-recognition": "^56.0.0",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "posthog-react-native": "^4.43.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-device-info": "^14.1.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-pcm-player-lite": "^0.1.3",
    "react-native-permissions": "^5.4.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.15.1",
    "react-native-toast-message": "^2.3.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-video": "^6.17.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-volume-manager": "^2.0.8",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^5.0.5"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@react-native-community/cli": "latest",
    "@types/d3-shape": "^3.1.7",
    "@types/react": "~19.0.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~9.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fallow": "^2.88.2",
    "patch-package": "^8.0.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "^5.8.3"
  },
  "private": true
}
