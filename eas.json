{
  "cli": {
    "version": ">= 16.4.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_BASE_URL": "https://api.speechworks.in",
        "PAYMENTS_ENABLED": "false",
        "REVENUECAT_ANDROID_API_KEY": "",
        "REVENUECAT_IOS_API_KEY": ""
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "API_BASE_URL": "https://api.speechworks.in",
        "EXPO_PUBLIC_POSTHOG_API_KEY": "phc_wFqhyXAxiNUrLp6uMaLSSkVoLAEk6Rzf6awp8SPoEXKx",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.posthog.com",
        "PAYMENTS_ENABLED": "false",
        "REVENUECAT_ANDROID_API_KEY": "",
        "REVENUECAT_IOS_API_KEY": ""
      }
    },
    "preview-apk": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a --no-daemon --no-parallel -Dorg.gradle.workers.max=2 -x lintVitalAnalyzeRelease"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "API_BASE_URL": "https://api.speechworks.in",
        "EXPO_PUBLIC_POSTHOG_API_KEY": "phc_wFqhyXAxiNUrLp6uMaLSSkVoLAEk6Rzf6awp8SPoEXKx",
        "EXPO_PUBLIC_POSTHOG_HOST": "https://eu.posthog.com",
        "PAYMENTS_ENABLED": "false",
        "REVENUECAT_ANDROID_API_KEY": "",
        "REVENUECAT_IOS_API_KEY": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
